{
  "name": "vladdress",
  "version": "1.2.0",
  "description": "Lightweight Street Address Parser Written in TypeScript",
  "keywords": [
    "address",
    "parser",
    "street"
  ],
  "homepage": "https://github.com/Christop406/vladdress#readme",
  "bugs": {
    "url": "https://github.com/Christop406/vladdress/issues"
  },
  "license": "MIT",
  "author": "Chris Gilardi <chris.gilardi@vidaloop.com> (https://chrisgilardi.com/)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Christop406/vladdress.git"
  },
  "files": [
    "build/**/*"
  ],
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "scripts": {
    "test": "vp test run",
    "start": "ts-node src/index.ts",
    "lint": "vp lint src/**/*.ts --fix",
    "prepublish": "pnpm run build",
    "build": "rimraf build && tsc",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "coveralls": "^3.1.1",
    "istanbul": "^0.4.5",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "vite-plus": "latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    }
  }
}
